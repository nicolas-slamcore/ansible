# Stream C: Orchestration + CLI
# ------------------------------------------------------------------


def update_device(
    host: str,
    version: str,
    bundles: dict[str, Path],
    cli_hw: str | None,
    progress: Progress,
) -> DeviceResult:
    """Orchestrate a full update on one device.

    :param host: Canonical hostname.
    :param version: Target version string.
    :param bundles: Map of hw variant → local .raucb path.
    :param cli_hw: Optional hw override from the CLI.
    :param progress: Rich Progress instance (shared across threads).
    :returns: DeviceResult describing the outcome.

    """
    result = DeviceResult(host=host, ok=False)

    # Per-device log file: captures every poll response, exception, and
    # final result for post-mortem when the summary table elides detail.
    log_dir = CACHE_DIR / "logs"
    log_dir.mkdir(parents=True, exist_ok=True)
    log_path = log_dir / f"{host}-{time.strftime('%Y%m%d-%H%M%S')}.log"
    result.log_path = log_path
    with log_path.open("w") as fh:
        fh.write(f"# aware-update log for {host}\n")
        fh.write(f"# started {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
        fh.write(f"# target version: {version}\n")

    try:
        hw = resolve_hw(host, cli_hw)
        with log_path.open("a") as fh:
            fh.write(f"# hw: {hw}\n")
        if hw not in bundles:
            result.error = f"No bundle for hw={hw} (downloaded: {sorted(bundles)})"
            return result

        client, token = login(host)
        auth = {"Authorization": f"Bearer {token}"}

        info = client.get("/unstable/system/info", headers=auth, timeout=15)
        info.raise_for_status()
        result.version_before = info.json()["system"]["info"]["software_version"]
        with log_path.open("a") as fh:
            fh.write(f"# version before: {result.version_before}\n")

        task_id = progress.add_task(f"[cyan]{host}[/cyan] uploading", total=1)
        upload_id = upload_bundle(
            client, token, bundles[hw], CHUNK_SIZE_DEFAULT, progress, task_id,
        )

        # Reset the task so TimeElapsedColumn keeps ticking during install
        # (it freezes once completed >= total at the end of upload).
        progress.reset(
            task_id, total=None, description=f"[cyan]{host}[/cyan] installing",
        )
        status, reason = trigger_and_poll(
            host, token, upload_id, result.version_before, version,
            progress, task_id, log_path,
        )

        if status != "success":
            result.error = f"Install {status}: {reason}"
            progress.update(task_id, description=f"[red]{host}[/red] failed")
            return result

        progress.update(task_id, description=f"[cyan]{host}[/cyan] verifying")
        result.version_after = verify_post_reboot(host, version)
        result.ok = True
        progress.update(
            task_id, description=f"[green]{host}[/green] {result.version_after}",
        )

    except httpx.HTTPStatusError as exc:
        result.error = f"HTTP {exc.response.status_code}: {exc.response.text[:120]}"
    except httpx.ConnectError:
        result.error = "Connection refused"
    except Exception as exc:  # noqa: BLE001
        result.error = f"{type(exc).__name__}: {exc}"

    with log_path.open("a") as fh:
        if result.ok:
            fh.write(f"[{time.strftime('%H:%M:%S')}] # final: ok ({result.version_after})\n")
        else:
            fh.write(f"[{time.strftime('%H:%M:%S')}] # final: failed — {result.error}\n")
    return result


def cleanup_bundles(bundles: dict[str, Path]) -> None:
    """Delete downloaded .raucb files and their empty parent directories."""
    for path in bundles.values():
        if path.exists():
            path.unlink()
            err.print(f"  Removed {path}")
        # Remove hw dir if empty, then version dir if empty.
        for parent in (path.parent, path.parent.parent):
            try:
                parent.rmdir()
            except OSError:
                pass


def print_summary(results: list[DeviceResult]) -> None:
    """Print a rich table summarising update outcomes for all devices."""
    table = Table(title="Update summary", show_lines=True)
    table.add_column("Device")
    table.add_column("Before")
    table.add_column("After")
    table.add_column("Status")
    for r in results:
        if r.ok:
            status = "[green]ok[/green]"
        else:
            status = f"[red]failed: {r.error}[/red]"
        table.add_row(r.host, r.version_before, r.version_after, status)
    Console().print(table)


app = typer.Typer(help="Update Slamcore Aware devices via their HTTP API.")


@app.command()
def main(
    devices: Annotated[
        list[str],
        typer.Option(
            "--device", "-d",
            help="Device host. Accepts short IDs (jpah0001) or full hostnames. Repeatable.",
        ),
    ],
    version: Annotated[
        Optional[str],
        typer.Option(
            "--version", "-v",
            help="Target version, e.g. 26.04.10. Defaults to latest on buildbot.",
        ),
    ] = None,
    hw: Annotated[
        Optional[str],
        typer.Option("--hw", help="Override hw variant for all devices: mk2 or mk3."),
    ] = None,
    jobs: Annotated[
        int,
        typer.Option("--jobs", "-j", help="Max parallel device updates. Default: min(devices, 8)."),
    ] = 0,
    dry_run: Annotated[
        bool,
        typer.Option(
            "--dry-run",
            help="Resolve version and download bundle(s), then exit without uploading.",
        ),
    ] = False,
    keep_cache: Annotated[
        bool,
        typer.Option(
            "--keep-cache",
            help="Keep downloaded .raucb bundles in ~/.cache/aware-update after the run.",
        ),
    ] = False,
) -> None:
    if not devices:
        err.print("[red]Provide at least one --device.[/red]")
        raise typer.Exit(1)
    if hw and hw not in ("mk2", "mk3"):
        err.print(f"[red]--hw must be mk2 or mk3, got {hw!r}[/red]")
        raise typer.Exit(1)

    hosts = [normalize_host(d) for d in devices]
    n_jobs = jobs or min(len(hosts), 8)

    err.print(f"Resolving version{'...' if version is None else f': {version}'}")
    target_version = resolve_version(version)
    err.print(f"Target version: [bold]{target_version}[/bold]")

    # Determine which hw variants are needed, then download (serial, max 2 variants).
    hws_needed: set[str] = set()
    if hw:
        hws_needed.add(hw)
    else:
        for host in hosts:
            try:
                hws_needed.add(resolve_hw(host, None))
            except Exception as exc:  # noqa: BLE001
                err.print(f"[red]HW detection failed for {host}: {exc}. Use --hw to override.[/red]")
                raise typer.Exit(1) from exc

    bundles: dict[str, Path] = {}
    for variant in sorted(hws_needed):
        err.print(f"Ensuring {variant} bundle for {target_version}...")
        bundles[variant] = ensure_bundle(target_version, variant)
        err.print(f"  [green]✓[/green] {bundles[variant]}")

    if dry_run:
        err.print("[yellow]Dry-run complete. Skipping upload.[/yellow]")
        if not keep_cache:
            cleanup_bundles(bundles)
        return

    results: list[DeviceResult] = []
    with Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        BarColumn(),
        MofNCompleteColumn(),
        TimeElapsedColumn(),
    ) as progress:
        with ThreadPoolExecutor(max_workers=n_jobs) as pool:
            futures = {
                pool.submit(update_device, host, target_version, bundles, hw, progress): host
                for host in hosts
            }
            for future in as_completed(futures):
                results.append(future.result())

    print_summary(results)

    log_results = [r for r in results if r.log_path]
    if log_results:
        err.print("\n[bold]Per-device logs:[/bold]")
        for r in log_results:
            marker = "[green]✓[/green]" if r.ok else "[red]✗[/red]"
            err.print(f"  {marker} {r.host}: {r.log_path}")

    if not keep_cache:
        cleanup_bundles(bundles)

    if any(not r.ok for r in results):
        raise typer.Exit(1)


if __name__ == "__main__":
    app()
