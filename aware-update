def normalize_host(name: str) -> str:
    """Expand a short device ID to the canonical fully-qualified hostname.

    :param name: Short ID (e.g. ``jpah0001``) or full hostname.
    :returns: Lowercase canonical hostname.

    """
    name = name.lower()
    if not name.startswith("sc-aware-"):
        return f"sc-aware-{name}"
    return name


def login(host: str) -> tuple[httpx.Client, str]:
    """Open an HTTP client and authenticate against the device API.

    :param host: Canonical hostname.
    :returns: Tuple of (client, bearer_token).
    :raises httpx.HTTPStatusError: On non-2xx login response.

    """
    client = httpx.Client(
        base_url=f"http://{host}",
        timeout=httpx.Timeout(30, connect=10),
    )
    resp = client.post(
        "/unstable/login",
        data={"username": "admin", "password": "password"},
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    resp.raise_for_status()
    return client, resp.json()["access_token"]


def _load_device_cache() -> dict:
    """Return the persisted hw-version cache, or {} if absent or corrupt."""
    if not DEVICES_CACHE.exists():
        return {}
    try:
        return json.loads(DEVICES_CACHE.read_text())
    except (json.JSONDecodeError, OSError):
        return {}


def _save_device_cache(cache: dict) -> None:
    """Persist the hw-version cache to disk.

    :param cache: Mapping to serialise to JSON.

    """
    DEVICES_CACHE.parent.mkdir(parents=True, exist_ok=True)
    DEVICES_CACHE.write_text(json.dumps(cache, indent=2))


def _hw_via_ssh(host: str) -> str:
    """Detect hardware revision by reading the device over SSH.

    Derives the SSH password from the eth0 MAC via the existing
    password_from_mac.sh script, then reads JETSON_FLASH_REV over SSH.

    :param host: Canonical hostname.
    :returns: ``"mk2"`` or ``"mk3"``.
    :raises RuntimeError: If any step fails to produce a usable result.

    """
    client, token = login(host)
    resp = client.get(
        "/unstable/settings/network/list",
        headers={"Authorization": f"Bearer {token}"},
    )
    client.close()
    resp.raise_for_status()

    mac: str | None = None
    for dev in resp.json().get("devices", []):
        if dev.get("device") == "eth0":
            mac = dev.get("mac_address")
            break
    if not mac:
        raise RuntimeError(f"eth0 MAC address not found on {host}")

    pw_out = subprocess.run(
        [str(PASSWORD_FROM_MAC), mac],
        capture_output=True,
        text=True,
        check=True,
    )
    match = re.search(r'Password .+ is "(\S+)"\.', pw_out.stdout)
    if not match:
        raise RuntimeError(f"Could not parse SSH password for {host}")
    password = match.group(1)

    ssh_out = subprocess.run(
        [
            "sshpass", "-p", password,
            "ssh",
            "-o", "StrictHostKeyChecking=no",
            "-o", "UserKnownHostsFile=/dev/null",
            "-o", "LogLevel=ERROR",
            "-o", "ConnectTimeout=8",
            f"slamcore@{host}",
            "cat", DEVICE_VARIANT_FILE,
        ],
        capture_output=True,
        text=True,
        check=True,
    )
    variant = ssh_out.stdout.strip()
    if variant in ("mk2", "mk3"):
        return variant
    raise RuntimeError(
        f"Unexpected content in {DEVICE_VARIANT_FILE} on {host}: {variant!r}"
    )


def resolve_hw(host: str, cli_hw: str | None) -> str:
    """Return the hardware revision for a host via a three-tier lookup.

    Priority: explicit CLI flag → KNOWN_HW dict → local cache → SSH detection.
    SSH results are cached and the user is reminded to commit them to KNOWN_HW.

    :param host: Canonical hostname.
    :param cli_hw: Hardware revision from the CLI, or ``None``.
    :returns: ``"mk2"`` or ``"mk3"``.

    """
    if cli_hw:
        return cli_hw
    if host in KNOWN_HW:
        return KNOWN_HW[host]

    cache = _load_device_cache()
    if "hw" in cache.get(host, {}):
        return cache[host]["hw"]

    hw = _hw_via_ssh(host)
    cache.setdefault(host, {})["hw"] = hw
    _save_device_cache(cache)
    err.print(
        f"[yellow]Detected {hw} for {host}. "
        "Consider adding it to KNOWN_HW in the script and committing.[/yellow]"
    )
    return hw


def upload_bundle(
    client: httpx.Client,
    token: str,
    bundle_path: Path,
    chunk_size: int,
    progress: Progress,
    task_id: TaskID,
) -> str:
    """Upload a bundle to the device in sequential chunks.

    :param client: Authenticated HTTP client.
    :param token: Bearer access token.
    :param bundle_path: Local path to the .raucb file.
    :param chunk_size: Bytes per chunk.
    :param progress: Rich Progress instance for reporting.
    :param task_id: Progress task to advance after each chunk.
    :returns: Upload session UUID.
    :raises RuntimeError: If a chunk exhausts all retries.

    """
    headers = {"Authorization": f"Bearer {token}"}

    init = client.post(
        "/unstable/system/upgrade",
        params={"upgrade_type": "system", "filename": bundle_path.name},
        headers=headers,
        timeout=30,
    )
    init.raise_for_status()
    upload_id: str = init.json()

    total = bundle_path.stat().st_size
    n_chunks = (total + chunk_size - 1) // chunk_size
    progress.update(task_id, total=n_chunks)

    with bundle_path.open("rb") as fh:
        for chunk_id in range(n_chunks):
            data = fh.read(chunk_size)
            for attempt in range(CHUNK_RETRIES):
                try:
                    r = client.put(
                        f"/unstable/system/upgrade/{upload_id}/upload/{chunk_id}",
                        headers=headers,
                        files={"file": (bundle_path.name, data, "application/octet-stream")},
                        timeout=httpx.Timeout(120, connect=10),
                    )
                    r.raise_for_status()
                    break
                except (httpx.HTTPStatusError, httpx.TransportError):
                    if attempt == CHUNK_RETRIES - 1:
                        raise RuntimeError(
                            f"Chunk {chunk_id} failed after {CHUNK_RETRIES} attempts"
                        )
                    time.sleep(2 ** attempt)
            progress.advance(task_id)

    return upload_id


def trigger_and_poll(
    host: str,
    token: str,
    upload_id: str,
    current_version: str,
    target_version: str,
    progress: Progress,
    task_id: TaskID,
    log_path: Path,
) -> tuple[str, str]:
    """Trigger the device upgrade and poll until a terminal state.

    Handles the reboot cycle: ConnectError / ReadTimeout are treated as an
    expected reboot, not a failure. A separate deadline bounds how long we
    wait for the device to come back. After reconnect, re-login to get a
    fresh token before resuming polling.

    :param host: Canonical hostname.
    :param token: Bearer token (used only for the initial trigger call).
    :param upload_id: Upload session UUID from `upload_bundle`.
    :param current_version: Version string before the upgrade, used as the
        poll path parameter.
    :param target_version: Expected post-upgrade version. Used as a fallback
        oracle via /system/info when the poll endpoint becomes unavailable
        after reboot.
    :param progress: Rich Progress instance for live status updates.
    :param task_id: Progress task to update with current poll phase.
    :param log_path: Per-device log file path; receives a line per poll
        transition, exception, and final result.
    :returns: Tuple of ``(status, reason)`` — status is ``"success"`` or
        ``"failed"``.

    """
    def _log(msg: str) -> None:
        with log_path.open("a") as fh:
            fh.write(f"[{time.strftime('%H:%M:%S')}] {msg}\n")

    client, fresh_token = login(host)
    headers = {"Authorization": f"Bearer {fresh_token}"}
    _log("logged in for trigger")

    trigger = client.post(
        f"/unstable/system/upgrade/{upload_id}/trigger",
        headers={"Authorization": f"Bearer {token}"},
        timeout=60,
    )
    trigger.raise_for_status()
    trigger_body = trigger.json()
    trigger_status: str = trigger_body.get("status_response", {}).get("status", "")
    trigger_reason: str = trigger_body.get("status_response", {}).get("reason", "")
    _log(f"trigger response: {json.dumps(trigger_body)}")
    if trigger_status == "failed":
        client.close()
        _log(f"result: trigger refused — {trigger_reason}")
        return "failed", f"trigger refused: {trigger_reason}"

    poll_start = time.monotonic()
    last_poll_body: dict = {}
    last_exception: str = ""
    last_info_state: str = ""
    rebooted = False
    reconnected = False

    def _elapsed() -> str:
        secs = int(time.monotonic() - poll_start)
        m, s = divmod(secs, 60)
        return f"{m}m{s:02d}s"

    def _set_desc(phase: str) -> None:
        progress.update(task_id, description=f"[cyan]{host}[/cyan] {phase} ({_elapsed()})")

    def _build_detail() -> str:
        parts = [f"elapsed {_elapsed()}"]
        if last_poll_body:
            parts.append(f"last response: {json.dumps(last_poll_body)}")
        if rebooted:
            parts.append(f"rebooted: yes, reconnected: {'yes' if reconnected else 'no'}")
        if last_exception:
            parts.append(f"last error: {last_exception}")
        return ", ".join(parts)

    overall_deadline = time.monotonic() + POLL_TIMEOUT
    reboot_deadline: float | None = None

    while time.monotonic() < overall_deadline:
        try:
            poll = client.get(
                f"/unstable/system/upgrade/{current_version}",
                headers=headers,
                timeout=15,
            )
            poll.raise_for_status()
            reboot_deadline = None  # connected: device is up, reset reboot window
            body = poll.json()
            if body != last_poll_body:
                _log(f"poll: {json.dumps(body)}")
            last_poll_body = body
            status: str = body.get("status", "ongoing")
            poll_reason: str = body.get("reason", "")
            label = status + (f": {poll_reason[:50]}" if poll_reason else "")
            _set_desc(f"installing [{label}]")
            if status == "success":
                client.close()
                _log(f"result: success ({poll_reason or '<no reason>'})")
                return "success", poll_reason
            if status == "failed":
                client.close()
                full_reason = (
                    f"device reported failure: {poll_reason or '<no reason>'} "
                    f"({_build_detail()})"
                )
                _log(f"result: {full_reason}")
                return "failed", full_reason

        except (
            httpx.ConnectError,
            httpx.ReadTimeout,
            httpx.TransportError,
            httpx.HTTPStatusError,
        ) as exc:
            # 4xx is a genuine client error — don't swallow it as "still rebooting".
            if isinstance(exc, httpx.HTTPStatusError) and exc.response.status_code < 500:
                raise
            last_exception = f"{type(exc).__name__}: {exc}"
            # After reconnect, the upgrade-status endpoint can become unavailable
            # (the upgrade context is gone once the device has booted into the new
            # version). Cross-check /system/info — if the device reports the target
            # version, treat the upgrade as successful.
            if reconnected and isinstance(exc, httpx.HTTPStatusError):
                info_state = ""
                try:
                    info = client.get(
                        "/unstable/system/info", headers=headers, timeout=15,
                    )
                    info.raise_for_status()
                    running = info.json()["system"]["info"]["software_version"]
                    if Version(running) == Version(target_version):
                        _log(
                            f"poll URL unavailable; /system/info confirms target {running}"
                        )
                        client.close()
                        return "success", f"verified via /system/info: {running}"
                    info_state = f"info reports {running}, target {target_version}"
                except (httpx.RequestError, httpx.HTTPStatusError) as info_exc:
                    info_state = (
                        f"info check failed: {type(info_exc).__name__}: {info_exc}"
                    )
                except (KeyError, ValueError) as info_exc:
                    info_state = (
                        f"info parse error: {type(info_exc).__name__}: {info_exc}"
                    )
                # Dedup: only log when the state changes, so 15 minutes of repeat
                # results produce one line per distinct state, not 90.
                if info_state and info_state != last_info_state:
                    _log(info_state)
                    last_info_state = info_state
            if not rebooted:
                _log(f"connection lost — assuming reboot: {last_exception}")
            rebooted = True
            if reboot_deadline is None:
                reboot_deadline = time.monotonic() + REBOOT_TIMEOUT
            if time.monotonic() > reboot_deadline:
                client.close()
                full_reason = f"Device did not come back after reboot ({_build_detail()})"
                _log(f"result: {full_reason}")
                return "failed", full_reason
            _set_desc("[yellow]rebooting...[/yellow]")
            time.sleep(POLL_INTERVAL)
            # Re-login after reboot to get a fresh token and a live connection.
            try:
                new_client, fresh_token = login(host)
                client.close()
                client = new_client
                headers = {"Authorization": f"Bearer {fresh_token}"}
                if not reconnected:
                    _log("reconnected after reboot")
                reconnected = True
            except (httpx.RequestError, httpx.HTTPStatusError) as relogin_exc:
                _log(f"re-login still failing: {type(relogin_exc).__name__}: {relogin_exc}")
            continue

        time.sleep(POLL_INTERVAL)

    full_reason = f"Polling timed out ({_build_detail()})"
    client.close()
    _log(f"result: {full_reason}")
    return "failed", full_reason


def verify_post_reboot(host: str, target_version: str) -> str:
    """Return the device's current software_version after an upgrade.

    Re-authenticates before querying so stale tokens are not an issue.
    The caller compares the returned string against ``target_version``.

    :param host: Canonical hostname.
    :param target_version: Expected version (unused internally; for caller).
    :returns: ``software_version`` string from the system info endpoint.

    """
    client, token = login(host)
    resp = client.get(
        "/unstable/system/info",
        headers={"Authorization": f"Bearer {token}"},
        timeout=15,
    )
    client.close()
    resp.raise_for_status()
    return resp.json()["system"]["info"]["software_version"]


