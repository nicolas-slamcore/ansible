# ------------------------------------------------------------------


def list_buildbot_versions() -> list[str]:
    """Return all available versions from the buildbot index, newest first.

    :returns: Semver-sorted descending list of version strings.
    :raises RuntimeError: If the index is unreachable or returns a non-200 status.

    """
    try:
        response = httpx.get(f"{BUILDBOT_BASE}/", timeout=10)
    except httpx.RequestError as exc:
        raise RuntimeError(f"Could not reach buildbot index: {exc}") from exc
    response.raise_for_status()
    versions = re.findall(r'href="(\d+\.\d+[^"/]*)/?', response.text)
    return sorted(set(versions), key=Version, reverse=True)


def resolve_version(requested: str | None) -> str:
    """Resolve a version string, or return the latest available from buildbot.

    :param requested: Explicit version string, or ``None`` to auto-resolve.
    :returns: The resolved version string.
    :raises RuntimeError: If auto-resolution finds no versions.

    """
    if requested is not None:
        return requested
    versions = list_buildbot_versions()
    if not versions:
        raise RuntimeError(
            f"No versions found on buildbot. Check that {BUILDBOT_BASE}/ is reachable."
        )
    return versions[0]


def ensure_bundle(version: str, hw: str) -> Path:
    """Return path to a cached .raucb bundle, downloading from buildbot on miss.

    Concurrent calls for the same (version, hw) pair are serialised via
    filelock so only one process pays the download cost.

    :param version: Version string, e.g. ``"26.1.34"``.
    :param hw: Hardware variant: ``"mk2"`` or ``"mk3"``.
    :returns: Absolute path to the extracted ``.raucb`` file.
    :raises RuntimeError: If the tarball has no .raucb member or download fails.

    """
    bundle_path = CACHE_DIR / "versions" / version / hw / f"aware_update_{version}.raucb"
    if bundle_path.exists():
        return bundle_path

    lock_path = CACHE_DIR / ".locks" / f"{version}-{hw}.lock"
    lock_path.parent.mkdir(parents=True, exist_ok=True)

    with FileLock(str(lock_path)):
        # Re-check after acquiring the lock — a concurrent caller may have
        # already populated the cache while we were waiting.
        if bundle_path.exists():
            return bundle_path

        bundle_path.parent.mkdir(parents=True, exist_ok=True)
        tarball_name = f"jetson-flash_rauc_{hw}-r36_aarch64_{version}.tbz2"
        tarball_url = f"{BUILDBOT_BASE}/{version}/aarch64/current/{tarball_name}"
        tarball_tmp = bundle_path.parent / tarball_name

        try:
            with httpx.stream(
                "GET",
                tarball_url,
                timeout=httpx.Timeout(300, connect=15),
                follow_redirects=True,
            ) as resp:
                resp.raise_for_status()
                with tarball_tmp.open("wb") as fh:
                    for chunk in resp.iter_bytes(chunk_size=256 * 1024):
                        fh.write(chunk)

            # Use a parallel bzip2 decompressor when available (lbzip2 or
            # pbzip2 scale across all cores; standard bzip2 is single-threaded
            # and very slow on 4+ GB archives).
            parallel_bzip2 = next(
                (p for p in ("lbzip2", "pbzip2")
                 if subprocess.run(["which", p], capture_output=True).returncode == 0),
                None,
            )
            tar_cmd = ["tar", "xf" if parallel_bzip2 else "xjf", str(tarball_tmp),
                       "--wildcards", "*.raucb", "-O"]
            if parallel_bzip2:
                tar_cmd.insert(1, f"--use-compress-program={parallel_bzip2}")
            # Stream directly to file — avoids loading 5+ GB into Python memory.
            try:
                with bundle_path.open("wb") as out_fh:
                    proc = subprocess.run(
                        tar_cmd, stdout=out_fh, stderr=subprocess.PIPE, check=True,
                    )
            except Exception:
                # Partial write; remove before re-raising so the cache stays clean.
                bundle_path.unlink(missing_ok=True)
                raise
            if bundle_path.stat().st_size == 0:
                bundle_path.unlink()
                raise RuntimeError(f"No .raucb found in {tarball_name}")
        finally:
            if tarball_tmp.exists():
                tarball_tmp.unlink()

    return bundle_path


